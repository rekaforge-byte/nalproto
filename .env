# PostgreSQL connection string (Railway provides this automatically as DATABASE_URL
# when you add a PostgreSQL plugin to your project)
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# Random secret used to sign admin session tokens.
# Generate one with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-random-generated-secret"

# Public URL of the deployed site (used for metadata / vCard links)
NEXT_PUBLIC_SITE_URL="https://nalproto.my"
